{
  "permissions": {
    "allow": [
      "Bash(git ls-remote *)",
      "Bash(grep -nE \"request.args.get\\\\\\(['\\\\\"]code|args\\\\.get\\\\\\\\\\(['\\\\\"]code\" apis/app/main.py)",
      "Bash(python -m py_compile apis/app/main.py)",
      "Bash(node -e \"console.log\\('python check skipped'\\)\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.automations/give-student-credit.py\" --event=claude || python \"$CLAUDE_PROJECT_DIR/.automations/give-student-credit.py\" --event=claude"
          }
        ]
      }
    ]
  }
}
