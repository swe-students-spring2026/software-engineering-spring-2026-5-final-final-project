GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Per-tier overrides for the chat speed selector.
GEMINI_MODEL_FAST=gemini-2.5-flash-lite
GEMINI_MODEL_BALANCED=
GEMINI_MODEL_SMART=gemini-2.5-pro

# Flask session encryption — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_flask_secret_key_here

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URI to: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here


SCRAPER_TERMS=auto
SCRAPE_INTERVAL_HOURS=24

PYTHON_IMAGE_TAG=3.14

MONGO_CONTAINER_NAME=database
API_CONTAINER_NAME=backend
FRONTEND_CONTAINER_NAME=frontend

MONGO_IMAGE_TAG=8.2.7
MONGO_PORT=27017
MONGO_URI=mongodb://mongo:27017/final_project
MONGO_DB_NAME=final_project

MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secret
MONGO_HOST=mongodb
MONGO_INTERNAL_PORT=27017
MONGO_AUTH_SOURCE=admin

API_PORT=8000
API_INTERNAL_PORT=8000
# Shared frontend-to-API secret. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
API_INTERNAL_TOKEN=generate_a_shared_internal_token_here

FRONTEND_PORT=3000
FRONTEND_INTERNAL_PORT=3000
FRONTEND_PUBLIC_URL=http://localhost:3000
