GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

PYTHON_IMAGE_TAG=3.14

API_CONTAINER_NAME=backend
FRONTEND_CONTAINER_NAME=frontend

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/final_project?appName=Cluster0
MONGO_DB_NAME=final_project

API_PORT=8000
API_INTERNAL_PORT=8000

FRONTEND_PORT=3000
FRONTEND_INTERNAL_PORT=3000

SCRAPER_TERMS=1268,1266
SCRAPE_INTERVAL_HOURS=24
