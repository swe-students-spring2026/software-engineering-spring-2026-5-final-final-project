# ── Frontend ──────────────────────────────────────────────────────────────────

# MongoDB connection string (MongoDB Atlas or local)
# Atlas example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
# Local example: mongodb://localhost:27017/cinematch
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/cinematch

# Secret key used to sign Flask sessions — use a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# Base URL of the recommendation-engine HTTP service.
# Local dev (running rec-engine directly): http://localhost:5001
# When running via docker-compose: http://recommendation-engine:5001
REC_API_URL=http://localhost:5001

# ── Recommendation Engine ─────────────────────────────────────────────────────

# Paths to the pre-built FAISS index and metadata parquet file.
# Generate these by running: python recommendation-engine/scripts/preprocess.py
INDEX_PATH=recommendation-engine/data/faiss.index
METADATA_PATH=recommendation-engine/data/metadata.parquet

EMBED_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5
NOMIC_QUERY_PREFIX=