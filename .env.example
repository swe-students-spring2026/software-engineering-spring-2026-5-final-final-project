# ── MongoDB ───────────────────────────────────────────────────────────────
# Use mongodb://localhost:27017 for local dev; mongodb://mongodb:27017 inside Docker.
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=pennywise

# ── Backend ───────────────────────────────────────────────────────────────
# Change JWT_SECRET to a long random string in production.
JWT_SECRET=dev-secret-change-in-prod

# ── Frontend ──────────────────────────────────────────────────────────────
# URL the frontend container uses to reach the backend.
BACKEND_URL=http://backend:5000
FLASK_SECRET=dev-frontend-secret

# ── CI/CD secrets (set these in GitHub → Settings → Secrets) ─────────────
# Docker Hub credentials
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=your-dockerhub-access-token

# DigitalOcean droplet SSH access
DO_HOST=your.droplet.ip.address
DO_USER=root
DO_SSH_KEY=your-ssh-private-key-contents
