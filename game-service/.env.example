# grader-service URL. In docker-compose this resolves via internal DNS.
GRADER_SERVICE_URL=http://localhost:8001

# port that game-service itself listens on
GAME_SERVICE_PORT=8000

# storage backend: "mock" (in-memory, phase 1) or "mongo" (phase 2)
DB_BACKEND=mock

# only used when DB_BACKEND=mongo
MONGO_URL=mongodb://localhost:27017
MONGO_DB=fish_likes_cat

# CORS: comma-separated origins allowed to hit this API
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000

LOG_LEVEL=INFO

# optional: defaults to ../data/judgeable_problems.json when present
PROBLEM_DATASET_PATH=
