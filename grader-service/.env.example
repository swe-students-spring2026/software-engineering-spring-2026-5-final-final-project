# Wall-clock timeout per /grade request, in seconds.
GRADER_TIMEOUT_SECONDS=10

# local = current in-container Python sandbox
# judge0 = forward assembled student + test harness to a Judge0-compatible API
GRADER_BACKEND=local
JUDGE0_API_URL=http://localhost:2358
JUDGE0_PYTHON_LANGUAGE_ID=71
JUDGE0_AUTH_TOKEN=
JUDGE0_RAPIDAPI_KEY=
JUDGE0_RAPIDAPI_HOST=

LOG_LEVEL=INFO
