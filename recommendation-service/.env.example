# MongoDB connection string. For local development with the docker-compose
# stack below, this is the default. For production, point this at the shared
# Atlas cluster (or whatever the team agrees on).
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=library_app

# Collection names. Change only if the team renames anything in the schema.
COLL_USERS=users
COLL_CHECKINS=checkins
COLL_ROOMS=rooms

# A checkin is treated as "live" if it is no older than this many minutes.
LIVE_WINDOW_MINUTES=30

# Weighted recommender: how heavily to favor live data over history (0..1).
LIVE_WEIGHT=0.7

# Defaults applied when no data exists at all (1-5 scale).
DEFAULT_CROWD=3.0
DEFAULT_QUIET=3.0
