# Flask
SECRET_KEY=change-me

# MongoDB
# Local dev (docker-compose): mongodb://mongo:27017
# Production (Atlas): mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/
MONGO_URI=mongodb://mongo:27017
MONGO_DB=campus_gigs

# Set to 1 to enable the dev login bypass (never use in production)
ENABLE_DEV_AUTH=1

# Email (SendGrid) — needed by the notification worker
SENDGRID_API_KEY=
MAIL_FROM_ADDRESS=

# Notification worker
WORKER_POLL_MINUTES=5
DIGEST_DAY=monday
DIGEST_HOUR=8
